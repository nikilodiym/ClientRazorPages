@page
@model ClientServiceRazor.Features.Clients.Pages.Index

@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Clients";
}

<div class="container mt-5">

    <!-- Add Client Form -->
    <div class="card shadow p-4 mb-5">
        <h3 class="mb-4 text-center">Add New Client</h3>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Surname</label>
                <input asp-for="NewClient.Surname" class="form-control" />
                <span asp-validation-for="NewClient.Surname" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">First Name</label>
                <input asp-for="NewClient.FirstName" class="form-control" />
                <span asp-validation-for="NewClient.FirstName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Patronymic</label>
                <input asp-for="NewClient.Patronymic" class="form-control" />
                <span asp-validation-for="NewClient.Patronymic" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="NewClient.Email" class="form-control" />
                <span asp-validation-for="NewClient.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Birth Date</label>
                <input asp-for="NewClient.BirthDate" type="date" class="form-control" />
                <span asp-validation-for="NewClient.BirthDate" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success w-100">
                Add Client
            </button>
        </form>
    </div>

    <!-- Clients List -->
    <div class="card shadow p-4">
        <h3 class="mb-4 text-center">Clients List</h3>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Surname</th>
                        <th>First Name</th>
                        <th>Email</th>
                        <th>Birth Date</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var client in Model.Clients)
                {
                    <tr>
                        <td>@client.Id</td>
                        <td>@client.Surname</td>
                        <td>@client.FirstName</td>
                        <td>@client.Email</td>
                        <td>@client.BirthDate.ToString("yyyy-MM-dd")</td>
                        <td class="text-center">
                            <a asp-page="/Features/Clients/Pages/Details"
                               asp-route-id="@client.Id"
                               class="btn btn-sm btn-outline-primary">
                                Details
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts{
    @* <partial name="_ValidationScriptsPartial"/> *@
}
