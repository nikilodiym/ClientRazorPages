@page "{clientId:int}"
@model ClientServiceRazor.Features.Clients.Pages.Address
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Client Address";
}

<div class="container mt-5">
    <div class="card shadow p-4">

        <h3 class="text-center mb-4">Client Address</h3>

        <form method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="AddressVm.ClientId" />

            <div class="mb-3">
                <label class="form-label">Country</label>
                <input asp-for="AddressVm.Country" class="form-control"/>
                <span asp-validation-for="AddressVm.Country" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">City</label>
                <input asp-for="AddressVm.City" class="form-control"/>
                <span asp-validation-for="AddressVm.City" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Street</label>
                <input asp-for="AddressVm.Street" class="form-control"/>
                <span asp-validation-for="AddressVm.Street" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Postal Code</label>
                <input asp-for="AddressVm.PostalCode" class="form-control"/>
                <span asp-validation-for="AddressVm.PostalCode" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-2">
                Save Address
            </button>
        </form>

        @if (Model.AddressExists)
        {
            <form method="post">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="btn btn-danger w-100"
                        asp-page-handler="Delete">
                    Delete Address
                </button>
            </form>
        }

    </div>
</div>
